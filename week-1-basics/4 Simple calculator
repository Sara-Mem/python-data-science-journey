def calculator():
    num_1 = float(input("Enter first number:"))
    op = input("Enter operator: (+ - * / // %)")
    num_2 = float(input("Enter second number:"))
    print (
        num_1 + num_2 if op == "+" else
        num_1 - num_2 if op == "-" else
        num_1 * num_2 if op == "*" else
        num_1 / num_2 if op == "/" else
        num_1 // num_2 if op == "//" else
        num_1 % num_2 if op == "%" else  "Invalid operator")

calculator()